{
  "name": "@venumdev/terminal",
  "version": "0.1.0",
  "description": "Real-time Solana DEX terminal powered by Venum API and OpenTUI",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "bin": {
    "venum-terminal": "src/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/solana-venum-terminal"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "solana",
    "defi",
    "terminal",
    "tui",
    "dex",
    "prices",
    "pools",
    "venum",
    "jito",
    "orca",
    "raydium",
    "meteora"
  ],
  "author": "Venum <hello@venum.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/venumhq/solana-venum-terminal"
  },
  "homepage": "https://venum.dev",
  "bugs": {
    "url": "https://github.com/venumhq/solana-venum-terminal/issues"
  },
  "dependencies": {
    "@opentui/core": "latest"
  }
}
